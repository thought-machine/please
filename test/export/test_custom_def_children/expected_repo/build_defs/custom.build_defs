def custom_target(
        name:str,
        srcs:list=[],
        outs:list=[],
        outs_adjacent:list=[]):
    genrule(
        name = f"{name}#adjacent",
        srcs = srcs,
        outs = outs_adjacent,
        cmd = "echo 'adjacent' > $OUT && cat $SRCS >> $OUT ",
    )
    return genrule(
        name = name,
        srcs = srcs,
        outs = outs,
        cmd = "echo 'main' > $OUT && cat $SRCS >> $OUT ",
    )
